Option Explicit

Public Sub OfuscarBAT_Base64()
    Dim inFile As String, outFile As String
    Dim batText As String, b64 As String, stub As String
    
    inFile = PickFile("Selecciona el BAT a ofuscar", "Batch Files (*.bat),*.bat")
    If Len(inFile) = 0 Then Exit Sub
    
    outFile = BuildOutputPath(inFile, "_obfuscated.bat")
    
    batText = ReadAllTextUtf8(inFile)
    b64 = ToBase64Utf8(batText)
    
    stub = BuildObfuscatedStub(b64)
    
    WriteAllTextAnsi outFile, stub
    
    MsgBox "BAT ofuscado generado:" & vbCrLf & outFile, vbInformation
End Sub

Private Function BuildObfuscatedStub(ByVal b64 As String) As String
    Dim chunks As Collection
    Dim i As Long, s As String
    Dim ps As String
    Dim tmpBatExpr As String
    Dim lines As String
    
    Set chunks = SplitEvery(b64, 120)
    
    lines = "@echo off" & vbCrLf
    lines = lines & "setlocal DisableDelayedExpansion" & vbCrLf
    lines = lines & "set ""__a=%temp%\%random%%random%.b64""" & vbCrLf
    lines = lines & "set ""__b=%temp%\%random%%random%.bat""" & vbCrLf
    lines = lines & "break > ""%__a%""" & vbCrLf
    
    For i = 1 To chunks.Count
        s = chunks(i)
        lines = lines & ">>""%__a%"" <nul set /p = " & s & vbCrLf
    Next i
    
    lines = lines & "powershell -NoProfile -ExecutionPolicy Bypass -Command " & QuoteForBat(BuildPowerShellDecodeCommand()) & vbCrLf
    lines = lines & "call ""%__b%""" & vbCrLf
    lines = lines & "del /q ""%__a%"" >nul 2>&1" & vbCrLf
    lines = lines & "del /q ""%__b%"" >nul 2>&1" & vbCrLf
    lines = lines & "endlocal" & vbCrLf
    
    BuildObfuscatedStub = lines
End Function

Private Function BuildPowerShellDecodeCommand() As String
    Dim ps As String
    
    ps = "$p1=$env:__a;" & _
         "$p2=$env:__b;" & _
         "$x=[System.IO.File]::ReadAllText($p1);" & _
         "$d=[System.Convert]::FromBase64String($x);" & _
         "$t=[System.Text.Encoding]::UTF8.GetString($d);" & _
         "[System.IO.File]::WriteAllText($p2,$t,[System.Text.Encoding]::ASCII)"
    
    BuildPowerShellDecodeCommand = ps
End Function

Private Function PickFile(ByVal title As String, ByVal filterText As String) As String
    Dim fd As FileDialog
    Set fd = Application.FileDialog(msoFileDialogFilePicker)
    
    With fd
        .Title = title
        .AllowMultiSelect = False
        .Filters.Clear
        .Filters.Add "BAT", "*.bat"
        If .Show <> -1 Then
            PickFile = vbNullString
        Else
            PickFile = .SelectedItems(1)
        End If
    End With
End Function

Private Function BuildOutputPath(ByVal inFile As String, ByVal suffix As String) As String
    Dim p As String, base As String, dotPos As Long
    
    dotPos = InStrRev(inFile, ".")
    If dotPos > 0 Then
        base = Left$(inFile, dotPos - 1)
    Else
        base = inFile
    End If
    
    BuildOutputPath = base & suffix
End Function

Private Function ReadAllTextUtf8(ByVal filePath As String) As String
    Dim stm As Object
    Set stm = CreateObject("ADODB.Stream")
    
    With stm
        .Type = 2
        .Charset = "utf-8"
        .Open
        .LoadFromFile filePath
        ReadAllTextUtf8 = .ReadText
        .Close
    End With
End Function

Private Sub WriteAllTextAnsi(ByVal filePath As String, ByVal txt As String)
    Dim f As Integer
    f = FreeFile
    
    Open filePath For Output As #f
    Print #f, txt;
    Close #f
End Sub

Private Function ToBase64Utf8(ByVal txt As String) As String
    Dim bytes() As Byte
    bytes = Utf8Bytes(txt)
    ToBase64Utf8 = Base64Encode(bytes)
End Function

Private Function Utf8Bytes(ByVal txt As String) As Byte()
    Dim stm As Object
    Set stm = CreateObject("ADODB.Stream")
    
    With stm
        .Type = 2
        .Charset = "utf-8"
        .Open
        .WriteText txt
        .Position = 0
        .Type = 1
        .Position = 3
        Utf8Bytes = .Read
        .Close
    End With
End Function

Private Function Base64Encode(ByRef arr() As Byte) As String
    Dim dom As Object, el As Object
    Set dom = CreateObject("MSXML2.DOMDocument")
    Set el = dom.createElement("b64")
    
    el.DataType = "bin.base64"
    el.nodeTypedValue = arr
    Base64Encode = Replace(el.Text, vbLf, "")
    Base64Encode = Replace(Base64Encode, vbCr, "")
End Function

Private Function SplitEvery(ByVal txt As String, ByVal n As Long) As Collection
    Dim c As New Collection
    Dim i As Long
    
    For i = 1 To Len(txt) Step n
        c.Add Mid$(txt, i, n)
    Next i
    
    Set SplitEvery = c
End Function

Private Function QuoteForBat(ByVal s As String) As String
    QuoteForBat = """" & Replace(s, """", "\""") & """"
End Function







