:menu
cls
call :banner
echo.
echo   %C_BOX%[1]%C_RESET% Matar app
echo   %C_BOX%[2]%C_RESET% Matar y resucitar
echo   %C_BOX%[3]%C_RESET% Consultar ultima ejecucion
echo   %C_BOX%[4]%C_RESET% Abrir URL historico
echo.
echo   %C_BOX%[5]%C_RESET% Salir
echo.
set "op="
set /p "op=Elige opcion: "

if "%op%"=="1" goto matar
if "%op%"=="2" goto reiniciar
if "%op%"=="3" goto consultar
if "%op%"=="4" goto historico
if "%op%"=="5" goto fin

echo.
echo %C_ERR%Opcion no valida.%C_RESET%
call :pause_short
goto menu

:: ==============================
:: OPCION 1
:: ==============================
:matar
cls
call :banner_small
echo.
echo %C_TITLE%[1] Cerrando app...%C_RESET%
echo.

call :is_running "%APP_EXE%"
if errorlevel 1 (
    echo %C_WARN%La app NO estaba en ejecucion.%C_RESET%
) else (
    taskkill /f /im "%APP_EXE%" >nul 2>&1
    echo %C_OK%App cerrada correctamente.%C_RESET%
)

echo.
pause
goto menu

:: ==============================
:: OPCION 2
:: ==============================
:reiniciar
cls
call :banner_small
echo.
echo %C_TITLE%[2] Reiniciando app...%C_RESET%
echo.

call :is_running "%APP_EXE%"
if errorlevel 1 (
    echo %C_WARN%La app NO estaba en ejecucion. Se lanzara ahora.%C_RESET%
) else (
    taskkill /f /im "%APP_EXE%" >nul 2>&1
    echo %C_OK%App cerrada.%C_RESET%
)

if exist "%APP_PATH%" (
    start "" "%APP_PATH%"
    echo %C_OK%App lanzada correctamente.%C_RESET%
) else (
    echo %C_ERR%No se encuentra el ejecutable:%C_RESET%
    echo %C_DIM%%APP_PATH%%C_RESET%
)

echo.
pause
goto menu

:: ==============================
:: OPCION 3
:: ==============================
:consultar
cls
call :banner_small
echo.
echo %C_TITLE%[3] Consultando ultima ejecucion...%C_RESET%
echo.

